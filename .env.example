# WeatherNext Pro — Environment Variables
# Copy this to .env and fill in your values

# Google Maps Platform Weather API
# Get from: https://console.cloud.google.com/apis/library/weather.googleapis.com
GMAPS_API_KEY=your_google_maps_api_key_here

# Polymarket CLOB credentials
# Get from: https://polymarket.com/settings (API section)
POLY_PRIVATE_KEY=your_polygon_wallet_private_key_here
POLY_API_KEY=your_polymarket_api_key_here
POLY_API_SECRET=your_polymarket_api_secret_here
POLY_API_PASSPHRASE=your_polymarket_api_passphrase_here

# Optional: Gemini AI for signal narrative generation
GEMINI_API_KEY=your_gemini_api_key_here
